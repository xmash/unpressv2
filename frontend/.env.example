# Copy to .env.local for local dev, and set the same in Netlify → Site → Env vars.
# Only NEXT_PUBLIC_* is exposed to the browser. Secrets are used ONLY by the
# Netlify functions (netlify/functions) — never shipped to the client.

# ── Public (browser) ───────────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
NEXT_PUBLIC_PAYPAL_CLIENT_ID=

# ── Secret (Netlify functions only) ────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_ENV=sandbox   # "sandbox" for testing, "live" for production
